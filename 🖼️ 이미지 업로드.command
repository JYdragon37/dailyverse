#!/bin/bash
# ───────────────────────────────────────────────────────
# DailyVerse — 이미지 업로드
# images_to_upload/ 하위 모든 폴더 재귀 탐색 → Firebase Storage 자동 업로드
# (하위 폴더째로 넣어도 OK, 이미 업로드된 파일은 자동 건너뜀)
# ───────────────────────────────────────────────────────

cd "$(dirname "$0")/scripts"

echo ""
echo "🖼️  DailyVerse 이미지 업로드"
echo "═══════════════════════════════════════"
echo "images_to_upload/ 폴더 재귀 탐색 중..."
echo "(하위 폴더 포함, 신규 파일만 업로드)"
echo ""

node upload_local_images.js

echo ""
echo "───────────────────────────────────────"
echo "✅ 완료! 이 창을 닫아도 됩니다."
echo "───────────────────────────────────────"
read -p "엔터를 누르면 창이 닫힙니다..." _
